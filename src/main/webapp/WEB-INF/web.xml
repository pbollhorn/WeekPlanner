<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	id="WebApp_ID" version="4.0">

	<display-name>Week Planner</display-name>

	<welcome-file-list>
		<welcome-file>plan</welcome-file>
	</welcome-file-list>

	<!-- Specify ApiController to handle API endpoints "/api/*" -->
	<servlet>
		<servlet-name>ApiController</servlet-name>
		<servlet-class>controller.ApiController</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>ApiController</servlet-name>
		<url-pattern>/api/*</url-pattern>
	</servlet-mapping>

	<!-- Specify PageController to handle user-facing URLs -->
	<servlet>
		<servlet-name>PageController</servlet-name>
		<servlet-class>controller.PageController</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>PageController</servlet-name>
		<url-pattern>/account</url-pattern>
		<url-pattern>/login</url-pattern>
		<url-pattern>/menu</url-pattern>
		<url-pattern>/plan</url-pattern>
		<url-pattern>/trial</url-pattern>
	</servlet-mapping>

<!--<session-config>-->
<!--    <session-timeout>3600</session-timeout>-->
<!--</session-config>-->


	<!--  Specify UTF-8 encoding-->
	<filter>
		<filter-name>encodingFilter</filter-name>
		<filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
		<init-param>
			<param-name>encoding</param-name>
			<param-value>UTF-8</param-value>
		</init-param>
	</filter>
	<filter-mapping>
		<filter-name>encodingFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>


</web-app>