<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  
 	<display-name>Week Planner</display-name>
     
 	<welcome-file-list>
    	<welcome-file>controller</welcome-file>
<!--    	<welcome-file>view.jsp</welcome-file>-->
<!--    	<welcome-file>view.html</welcome-file>-->
 	</welcome-file-list>
  
    <!-- Specify ControllerServlet with URL "/controller" -->
 	<servlet>  
    	<servlet-name>ControllerServlet</servlet-name>  
    	<servlet-class>weekplanner.Controller</servlet-class>  
  	</servlet>  
 	<servlet-mapping>  
    	<servlet-name>ControllerServlet</servlet-name>  
 		<url-pattern>/controller/*</url-pattern>  
  	</servlet-mapping>
  
  
 	<!--  Specify UTF-8 encoding-->
 	<filter>
		<filter-name>encodingFilter</filter-name>
		<filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
		<init-param>
        	<param-name>encoding</param-name>
			<param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>encodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
  
  
  	
  	
  
  
  
  
</web-app>